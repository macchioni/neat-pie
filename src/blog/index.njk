---
layout: default.html
description: notes and ideas
---

<h1>{{title}}</h1>

<h3>{{description}}</h3>

<br />

<ul class="post-list">
  {% for post in collections.posts | reverse %}
    {% if not post.data.rss_only %}
    <li>
      <span class="post-date">{{ post.date | readableDate("YYYY · MM") }}</span>
      <a href="{{ post.url }}">{{ post.data.title }}</a>
    </li>
    {% endif %}
  {% endfor %}
</ul>